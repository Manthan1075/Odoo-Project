# VendorBridge ERP - Environment Configuration Template
# Copy this file to .env and fill in your values

# Database Configuration
DATABASE_PATH=vendorbridge.db

# JWT Configuration
SECRET_KEY=vendorbridge_secret_key_2026
ALGORITHM=HS256
TOKEN_EXPIRE_HOURS=24

# Email Configuration (Gmail SMTP)
SENDER_EMAIL=vendorbridge.erp@gmail.com
SENDER_PASSWORD=your_gmail_app_password_here
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Application Configuration
APP_TITLE=VendorBridge ERP
APP_VERSION=1.0.0
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=False

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# Default Admin User
DEFAULT_ADMIN_EMAIL=admin@vendorbridge.com
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_FIRST_NAME=Admin
DEFAULT_ADMIN_LAST_NAME=User
